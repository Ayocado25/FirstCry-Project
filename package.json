{
  "name": "daycare-tracker",
  "version": "1.0.0",
  "private": true,
  "description": "Root convenience scripts for Daycare Routine Tracker. The real apps live in /backend and /frontend, each with their own package.json.",
  "scripts": {
    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev": "npx concurrently -n BACKEND,FRONTEND -c blue,green \"npm:dev:backend\" \"npm:dev:frontend\"",
    "db:migrate": "npm run db:migrate --prefix backend",
    "db:seed": "npm run db:seed --prefix backend",
    "build:frontend": "npm run build --prefix frontend",
    "test:backend": "npm test --prefix backend",
    "test:frontend": "npm test --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
